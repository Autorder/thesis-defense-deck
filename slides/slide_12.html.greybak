<!doctype html><html><head><meta charset="utf-8"><style>
  :root{
    --page-bg:#e9ebe6; --panel:#ffffff; --page-fg:#1b2622; --cap-fg:#5b665f; --hair:#d3d8d0;
    --pine:#12514A; --teal:#1F7A5A; --gold:#9C6A15; --amber:#E8A310; --red:#B23A3A;
    --ground:#f4f5f3; --ink:#16211e; --mut:#68726b; --rowbd:#e4e8e2;
    --c-blue:#2a5a7a; --c-teal:#1f7a5a; --c-gold:#9c6a15;
  }
  @media (prefers-color-scheme:dark){:root{--page-bg:#12161a;--panel:#1b2027;--page-fg:#e7ebe6;--cap-fg:#9aa39c;--hair:#2a323a;}}
  :root[data-theme="dark"]{--page-bg:#12161a;--panel:#1b2027;--page-fg:#e7ebe6;--cap-fg:#9aa39c;--hair:#2a323a;}
  :root[data-theme="light"]{--page-bg:#e9ebe6;--panel:#ffffff;--page-fg:#1b2622;--cap-fg:#5b665f;--hair:#d3d8d0;}

  *{box-sizing:border-box}
  body{margin:0;background:var(--page-bg);color:var(--page-fg);
    font-family:system-ui,-apple-system,"Segoe UI",Helvetica,Arial,sans-serif;-webkit-font-smoothing:antialiased;}
  .wrap{max-width:1120px;margin:0 auto;padding:36px 24px 80px;}
  header.top .ey{font-size:.72rem;letter-spacing:.16em;text-transform:uppercase;color:var(--teal);font-weight:700;}
  header.top h1{font-size:clamp(1.4rem,2.6vw,1.9rem);margin:.3em 0 .2em;text-wrap:balance;}
  header.top p{margin:.2em 0;color:var(--cap-fg);max-width:66ch;line-height:1.55;}

  .slidewrap{margin:30px 0;}
  .slidewrap>.lbl{display:flex;align-items:baseline;gap:10px;margin-bottom:9px;}
  .slidewrap>.lbl b{font-size:1rem;} .slidewrap>.lbl .st{font-size:.85rem;color:var(--cap-fg);}
  .slidewrap>.lbl .ok{font-size:.72rem;font-weight:700;color:#fff;background:var(--teal);border-radius:20px;padding:2px 10px;letter-spacing:.04em;}
  .slidewrap>.lbl .rev{font-size:.72rem;font-weight:700;color:#fff;background:var(--amber);border-radius:20px;padding:2px 10px;letter-spacing:.04em;}

  .slide{container-type:inline-size;position:relative;width:100%;aspect-ratio:16/9;
    background:var(--ground);color:var(--ink);border-radius:10px;box-shadow:0 6px 26px rgba(0,0,0,.16);
    overflow:hidden;border:1px solid rgba(0,0,0,.06);}
  .pad{position:absolute;inset:0;padding:3.8cqw 5cqw;display:flex;flex-direction:column;}
  .kick{font-size:1.6cqw;letter-spacing:.14em;text-transform:uppercase;color:var(--teal);font-weight:800;}
  .snum{position:absolute;top:4.2cqw;right:4.6cqw;width:5.2cqw;height:5.2cqw;border-radius:50%;
    background:var(--amber);color:#fff;display:flex;align-items:center;justify-content:center;font-weight:800;font-size:2.5cqw;}
  .ttl{font-size:4.3cqw;line-height:1.05;font-weight:800;color:var(--pine);margin:.6cqw 0 0;max-width:84%;}

  /* ---- old-style agenda rows, improved ---- */
  .rows{flex:1;display:flex;flex-direction:column;justify-content:center;gap:1.05cqw;margin-top:.4cqw;}
  .row{display:grid;grid-template-columns:auto 1fr auto;align-items:center;gap:2.2cqw;
    background:#fff;border:1px solid var(--rowbd);border-left:.8cqw solid var(--accent,var(--pine));
    border-radius:1.4cqw;padding:1.2cqw 2.4cqw;box-shadow:0 1px 3px rgba(0,0,0,.04);}
  .row .rn{width:4.4cqw;height:4.4cqw;border-radius:50%;background:var(--amber);color:#fff;flex:none;
    display:flex;align-items:center;justify-content:center;font-weight:800;font-size:2.2cqw;}
  .row .rt{font-size:2.5cqw;font-weight:800;color:var(--pine);line-height:1.08;}
  .row .rg{display:flex;flex-wrap:wrap;gap:.65cqw;justify-content:flex-end;max-width:34cqw;justify-self:end;}
  .row .rg span{font-size:1.5cqw;font-weight:700;color:var(--accent);background:var(--accent-bg);
    border-radius:.8cqw;padding:.4cqw 1.15cqw;white-space:nowrap;line-height:1.2;}
  .row.blue{--accent:#2a5a7a;--accent-bg:#eaf0f5;}
  .row.teal{--accent:#1f7a5a;--accent-bg:#e2f0ea;}
  .row.gold{--accent:#9c6a15;--accent-bg:#fbeed2;}

  /* ---- slide 3: three concept cards + bottom strip ---- */
  .cards3{flex:1;display:flex;gap:2.2cqw;margin-top:1.4cqw;}
  .card3{flex:1;background:#fff;border:1px solid var(--rowbd);border-top:.9cqw solid var(--accent,var(--pine));
    border-radius:1.6cqw;padding:2.6cqw 2cqw 2.4cqw;display:flex;flex-direction:column;align-items:center;
    text-align:center;box-shadow:0 1px 3px rgba(0,0,0,.05);}
  .card3 .h{font-size:2cqw;font-weight:800;color:var(--accent);letter-spacing:.01em;}
  .card3 .big{font-size:3.3cqw;font-weight:800;color:var(--pine);line-height:1.04;margin:2.2cqw 0;}
  .card3 .sub{font-size:1.78cqw;color:var(--mut);line-height:1.32;margin-top:auto;}
  .card3.teal{--accent:#1f7a5a;} .card3.blue{--accent:#2a5a7a;} .card3.gold{--accent:#9c6a15;}
  .strip{margin-top:2cqw;background:var(--pine);color:#f4cd78;border-radius:1.4cqw;
    padding:1.7cqw 2.6cqw;text-align:center;font-size:1.98cqw;font-weight:800;line-height:1.3;}
  .strip b{color:#fff;}

  /* ---- slide 4: bullets (left) + central-question box (right) ---- */
  .split4{flex:1;display:grid;grid-template-columns:1.12fr 1fr;gap:3cqw;align-items:center;margin-top:1.4cqw;}
  .blist{display:flex;flex-direction:column;gap:1.6cqw;}
  .bitem{background:#fff;border:1px solid var(--rowbd);border-left:.8cqw solid var(--accent,var(--pine));
    border-radius:1.3cqw;padding:1.35cqw 2cqw;font-size:2.02cqw;color:var(--ink);line-height:1.24;font-weight:600;
    box-shadow:0 1px 3px rgba(0,0,0,.04);}
  .bitem b{color:var(--accent);font-weight:800;}
  .bitem.teal{--accent:#1f7a5a;} .bitem.gold{--accent:#9c6a15;} .bitem.blue{--accent:#2a5a7a;}
  .cqbox4{background:var(--pine);border-radius:2.2cqw;padding:2.8cqw 2.8cqw 3cqw;color:#fff;height:100%;
    display:flex;flex-direction:column;justify-content:center;}
  .cqbox4 .head{display:flex;align-items:center;gap:1.6cqw;margin-bottom:2.2cqw;}
  .cqbox4 .dot{width:4.6cqw;height:4.6cqw;border-radius:50%;background:var(--amber);color:#fff;flex:none;
    display:flex;align-items:center;justify-content:center;font-size:2.6cqw;font-weight:800;}
  .cqbox4 .hlab{font-size:1.85cqw;font-weight:800;color:#f4cd78;text-transform:uppercase;letter-spacing:.05em;}
  .cqbox4 .q{font-size:2.95cqw;font-weight:800;line-height:1.22;}
  .cqbox4 .q b{color:#f4cd78;}

  /* ---- slide 5: central-question banner + Q1-Q4 rows ---- */
  .cq5{background:#e6f1ec;border:1px solid #cfe3d8;border-left:.85cqw solid #1f7a5a;
    border-radius:1.5cqw;padding:1.6cqw 2.5cqw;margin-top:1.1cqw;}
  .cq5 .lab{font-size:1.65cqw;font-weight:800;color:#1f7a5a;text-transform:uppercase;letter-spacing:.06em;margin-bottom:.7cqw;}
  .cq5 .txt{font-size:2.45cqw;font-weight:800;color:var(--pine);line-height:1.22;}
  .cq5 .txt b{color:#1f7a5a;}
  .qrows{display:flex;flex-direction:column;gap:1cqw;margin-top:1.3cqw;}
  .qrow{display:grid;grid-template-columns:auto 1fr;align-items:center;gap:2.2cqw;background:#fff;
    border:1px solid var(--rowbd);border-left:.8cqw solid var(--accent,var(--pine));border-radius:1.3cqw;
    padding:1.05cqw 2.2cqw;box-shadow:0 1px 3px rgba(0,0,0,.04);}
  .qrow .qc{background:var(--amber);color:#fff;font-weight:800;font-size:1.95cqw;border-radius:1cqw;
    padding:.55cqw 1.4cqw;flex:none;}
  .qrow .qt{font-size:2.08cqw;font-weight:600;color:var(--ink);line-height:1.2;}
  .qrow.teal{--accent:#1f7a5a;} .qrow.gold{--accent:#9c6a15;} .qrow.blue{--accent:#2a5a7a;}

  /* ---- slide 6: bullets + 15-stat, gap banner, 4 contribution cards ---- */
  .l6top{display:grid;grid-template-columns:1.55fr 1fr;gap:2.6cqw;margin-top:.8cqw;align-items:stretch;}
  .l6bul{display:flex;flex-direction:column;gap:1cqw;justify-content:center;}
  .stat15{background:var(--pine);border-radius:1.8cqw;display:flex;flex-direction:column;align-items:center;
    justify-content:center;padding:1.4cqw;text-align:center;}
  .stat15 .num{font-size:6.6cqw;font-weight:800;color:var(--amber);line-height:.88;letter-spacing:-.02em;}
  .stat15 .cap2{font-size:1.6cqw;color:#d7e8e2;margin-top:.7cqw;line-height:1.2;}
  .gapbar{background:#e6f1ec;border:1px solid #cfe3d8;border-left:.85cqw solid #1f7a5a;border-radius:1.4cqw;
    padding:1.15cqw 2.4cqw;margin-top:.9cqw;font-size:1.95cqw;font-weight:700;color:var(--ink);line-height:1.26;}
  .gapbar b{color:#1f7a5a;font-weight:800;}
  .clabel{font-size:1.6cqw;font-weight:800;color:var(--mut);text-transform:uppercase;letter-spacing:.05em;margin:.9cqw 0 0;}
  .contribs{display:grid;grid-template-columns:repeat(4,1fr);gap:1.4cqw;margin-top:.7cqw;}
  .ccard{background:#fff;border:1px solid var(--rowbd);border-top:.85cqw solid var(--accent,var(--pine));
    border-radius:1.4cqw;padding:1.25cqw 1.4cqw;box-shadow:0 1px 3px rgba(0,0,0,.04);}
  .ccard .cnum{width:3.3cqw;height:3.3cqw;border-radius:50%;background:var(--amber);color:#fff;font-weight:800;
    font-size:1.8cqw;display:flex;align-items:center;justify-content:center;margin-bottom:.7cqw;}
  .ccard h5{margin:0;font-size:1.9cqw;font-weight:800;color:var(--pine);line-height:1.08;}
  .ccard p{margin:.5cqw 0 0;font-size:1.5cqw;color:var(--mut);line-height:1.22;}
  .ccard.teal{--accent:#1f7a5a;} .ccard.blue{--accent:#2a5a7a;} .ccard.gold{--accent:#9c6a15;} .ccard.pine{--accent:#12514A;}

  /* ---- slide 7: bullets + 8,760 stat, output-metric pills ---- */
  .l7top{display:grid;grid-template-columns:1.5fr 1fr;gap:2.8cqw;margin-top:.8cqw;align-items:stretch;}
  .l7bul{display:flex;flex-direction:column;gap:.75cqw;justify-content:center;}
  .stat8{background:#1f7a5a;border-radius:1.8cqw;display:flex;flex-direction:column;align-items:center;
    justify-content:center;padding:1.6cqw;text-align:center;}
  .stat8 .num{font-size:7cqw;font-weight:800;color:#fff;line-height:.9;letter-spacing:-.02em;}
  .stat8 .cap2{font-size:1.95cqw;color:#d7ede4;margin-top:1cqw;font-weight:700;line-height:1.24;}
  .stat8 .cap2 b{display:block;font-size:2.35cqw;color:#fff;font-weight:800;margin-bottom:.35cqw;}
  .stat8 .years{margin-top:1.3cqw;padding-top:1.1cqw;border-top:1.5px solid rgba(255,255,255,.28);
    font-size:2.1cqw;font-weight:800;color:#f4cd78;line-height:1.15;}
  .mlabel{font-size:1.62cqw;font-weight:800;color:#1f7a5a;text-transform:uppercase;letter-spacing:.05em;margin-top:.8cqw;}
  .metrics{display:grid;grid-template-columns:repeat(3,1fr);gap:1.6cqw;margin-top:.55cqw;}
  .mpill{border-radius:1.3cqw;padding:1.2cqw 1cqw;text-align:center;font-size:2cqw;font-weight:800;
    background:var(--mbg);color:var(--mfg);border:1px solid var(--mbd);border-bottom:.6cqw solid var(--mfg);}
  .mpill.teal{--mbg:#e2f0ea;--mfg:#1f7a5a;--mbd:#cfe3d8;}
  .mpill.blue{--mbg:#eaf0f5;--mfg:#2a5a7a;--mbd:#d3e0ea;}
  .mpill.gold{--mbg:#fbeed2;--mfg:#9c6a15;--mbd:#ecdcb0;}

  /* ---- slide 8: five-step horizontal flow + strip ---- */
  .flow8{flex:1;display:flex;align-items:stretch;gap:.5cqw;margin-top:1.6cqw;}
  .step8{flex:1;background:#fff;border:1px solid var(--rowbd);border-top:.9cqw solid var(--accent,var(--pine));
    border-radius:1.5cqw;padding:1.9cqw 1.1cqw;display:flex;flex-direction:column;align-items:center;
    text-align:center;box-shadow:0 1px 3px rgba(0,0,0,.05);}
  .step8 .n{width:4.6cqw;height:4.6cqw;border-radius:50%;background:var(--amber);color:#fff;font-weight:800;
    font-size:2.4cqw;display:flex;align-items:center;justify-content:center;margin-bottom:1.1cqw;}
  .step8 h5{margin:0;font-size:2.3cqw;font-weight:800;color:var(--pine);}
  .step8 p{margin:.85cqw 0 0;font-size:1.6cqw;color:var(--mut);line-height:1.24;}
  .step8.teal{--accent:#1f7a5a;} .step8.blue{--accent:#2a5a7a;} .step8.gold{--accent:#9c6a15;}
  .arr8{align-self:center;color:var(--amber);font-size:3cqw;font-weight:800;flex:none;}
  .svgwrap{flex:1;min-height:0;margin-top:1cqw;display:flex;}
  .svgwrap svg{width:100%;height:100%;}
  .strip8{margin-top:1.4cqw;background:var(--pine);border-radius:1.5cqw;padding:1.8cqw 2.6cqw;text-align:center;}
  .strip8 .big{font-size:2.2cqw;font-weight:800;color:#f4cd78;line-height:1.2;}
  .strip8 .small{font-size:1.82cqw;color:#e6f4ee;margin-top:.6cqw;font-weight:600;line-height:1.25;}

  /* ---- slide 9: three component cards with illustrations ---- */
  .l9{flex:1;display:flex;flex-direction:column;justify-content:center;margin-top:1cqw;}
  .l9cards{display:grid;grid-template-columns:repeat(3,1fr);gap:2.2cqw;}
  .l9card{background:#fff;border:1px solid var(--rowbd);border-top:.9cqw solid var(--accent,var(--pine));
    border-radius:1.8cqw;padding:1.5cqw 1.4cqw 1.9cqw;display:flex;flex-direction:column;align-items:center;
    text-align:center;box-shadow:0 1px 3px rgba(0,0,0,.05);}
  .l9card img{height:11.3cqw;width:100%;object-fit:contain;margin-bottom:.3cqw;}
  .l9card .big{font-size:4.5cqw;font-weight:800;color:var(--pine);line-height:1;letter-spacing:-.02em;font-variant-numeric:tabular-nums;}
  .l9card .lab{font-size:2cqw;font-weight:800;color:var(--accent,var(--teal));margin-top:.45cqw;}
  .l9card .sub{font-size:1.48cqw;color:var(--mut);margin-top:.5cqw;line-height:1.24;}
  .l9card.teal{--accent:#1f7a5a;} .l9card.gold{--accent:#9c6a15;} .l9card.blue{--accent:#2a5a7a;}
  .refstrip{margin-top:1.4cqw;background:var(--pine);border-radius:1.6cqw;padding:1.5cqw 2.2cqw;
    display:flex;align-items:center;gap:2cqw;}
  .refstrip .pill{background:var(--amber);color:#fff;font-weight:800;font-size:1.75cqw;border-radius:1.2cqw;
    padding:.7cqw 1.7cqw;flex:none;white-space:nowrap;}
  .refstrip .txt{color:#fff;font-size:1.85cqw;line-height:1.3;font-weight:600;}
  .refstrip .txt b{color:#f4cd78;}

  /* ---- slide 10: base-case map + 3 study cards ---- */
  .l10{flex:1;display:flex;flex-direction:column;margin-top:1cqw;min-height:0;}
  .l10row{flex:1;display:grid;grid-template-columns:0.86fr 1.45fr;gap:2.2cqw;min-height:0;}
  .basecard{background:#fff;border:1px solid var(--rowbd);border-top:.9cqw solid var(--pine);
    border-radius:1.8cqw;padding:1cqw 1cqw .9cqw;display:flex;flex-direction:column;align-items:center;
    text-align:center;box-shadow:0 1px 3px rgba(0,0,0,.05);}
  .basecard .bt{font-size:1.75cqw;font-weight:800;color:var(--pine);text-transform:uppercase;letter-spacing:.05em;}
  .mapwrap{position:relative;width:100%;aspect-ratio:1;margin:.3cqw 0;flex:0 0 auto;}
  .mapwrap img{width:100%;height:100%;object-fit:contain;display:block;}
  .pin{position:absolute;z-index:2;white-space:nowrap;}
  .pin.left{transform:translate(-100%,-50%);padding-right:1.1cqw;}
  .pin.right{transform:translate(0,-50%);padding-left:1.1cqw;}
  .pin .dot{width:1.7cqw;height:1.7cqw;border-radius:50%;background:#E8A310;border:.28cqw solid #fff;
    box-shadow:0 .15cqw .5cqw rgba(0,0,0,.45);flex:none;}
  .pin .lab{font-size:1.5cqw;font-weight:800;color:#12514A;background:rgba(255,255,255,.94);
    border-radius:.6cqw;padding:.1cqw .7cqw;white-space:nowrap;box-shadow:0 1px 2px rgba(0,0,0,.12);}
  .bcombo{font-size:1.5cqw;color:var(--mut);line-height:1.28;}
  .bcombo b{color:var(--pine);font-weight:800;font-size:1.62cqw;}
  .studies{display:flex;flex-direction:column;gap:1cqw;justify-content:flex-start;min-height:0;}
  .studycard{display:grid;grid-template-columns:auto 1fr auto;align-items:center;gap:1.6cqw;background:#fff;
    border:1px solid var(--rowbd);border-left:.8cqw solid var(--accent,var(--pine));border-radius:1.5cqw;
    padding:.7cqw 1.8cqw;box-shadow:0 1px 3px rgba(0,0,0,.05);}
  .studycard img{height:7.2cqw;width:7.2cqw;object-fit:contain;}
  .studycard .st{font-size:1.5cqw;font-weight:800;color:var(--accent);text-transform:uppercase;letter-spacing:.04em;}
  .studycard .h{font-size:2.15cqw;font-weight:800;color:var(--pine);line-height:1.08;margin:.1cqw 0;}
  .studycard .d{font-size:1.6cqw;color:var(--mut);line-height:1.2;}
  .studycard .runs{font-size:2.2cqw;font-weight:800;color:var(--accent);white-space:nowrap;text-align:center;line-height:1;}
  .studycard .runs small{display:block;font-size:1.3cqw;color:var(--mut);font-weight:700;margin-top:.2cqw;}
  .studycard.gold{--accent:#9c6a15;} .studycard.teal{--accent:#1f7a5a;} .studycard.blue{--accent:#2a5a7a;}
  .totstrip{margin-top:auto;background:var(--pine);border-radius:1.5cqw;padding:1.4cqw 2.4cqw;text-align:center;}
  .totstrip b{color:#f4cd78;font-size:2.2cqw;font-weight:800;}
  .totstrip span{color:#e6f4ee;font-size:1.85cqw;font-weight:600;}

  /* ---- slide 11: degradation graph + hero + cards ---- */
  .l11{flex:1;display:grid;grid-template-columns:1fr 0.82fr;gap:2.2cqw;margin-top:1cqw;min-height:0;align-items:center;}
  .l11left{display:flex;flex-direction:column;gap:1.1cqw;min-height:0;justify-content:center;}
  .hero11{background:var(--pine);border-radius:1.8cqw;padding:1.5cqw 1cqw;text-align:center;}
  .hero11 .n{font-size:5.2cqw;font-weight:800;color:var(--amber);line-height:1;letter-spacing:-.01em;}
  .hero11 .c{font-size:1.6cqw;color:#d7e8e2;margin-top:.6cqw;font-weight:600;line-height:1.25;}
  .l11graph{background:#fff;border:1px solid var(--rowbd);border-radius:1.4cqw;padding:.9cqw;
    display:flex;align-items:center;justify-content:center;box-shadow:0 1px 3px rgba(0,0,0,.05);min-height:0;}
  .l11graph img{width:100%;height:100%;object-fit:contain;}

  /* ---- slide 11 v2: clean graph + battery config table ---- */
  .l11right{display:flex;flex-direction:column;justify-content:center;gap:1.2cqw;min-height:0;}
  .bt2{font-size:2cqw;font-weight:800;color:var(--pine);}
  table.bcfg{width:100%;border-collapse:collapse;font-variant-numeric:tabular-nums;}
  table.bcfg th{font-size:1.5cqw;color:var(--mut);text-transform:uppercase;letter-spacing:.04em;
    padding:.9cqw .6cqw;border-bottom:.35cqw solid var(--pine);text-align:center;font-weight:700;}
  table.bcfg th:first-child{text-align:left;}
  table.bcfg td{font-size:2.1cqw;font-weight:700;padding:1cqw .6cqw;text-align:center;
    border-bottom:.16cqw solid #dde3dd;color:var(--ink);}
  table.bcfg td:first-child{text-align:left;color:var(--pine);font-weight:800;}
  table.bcfg td.u{color:#1f7a5a;} table.bcfg td.p{color:#9c6a15;}
  .note11{font-size:1.42cqw;color:#33403a;line-height:1.35;background:#eef2ee;border:1px solid #dbe4dd;
    border-radius:1.1cqw;padding:1cqw 1.3cqw;}
  .note11 b{color:var(--pine);}

  table.bcfg th.grp{text-align:center;font-size:1.5cqw;padding:.45cqw;border-bottom:none;color:#12514A;font-weight:800;border-radius:.6cqw .6cqw 0 0;}
  table.bcfg th.g0{background:#e4ecea;} table.bcfg th.g9{background:#fbeed2;color:#9c6a15;}
  table.bcfg th.sub{font-size:1.3cqw;padding:.45cqw .2cqw;border-bottom:.32cqw solid var(--pine);text-transform:none;letter-spacing:0;}
  table.bcfg.y09 td{font-size:1.75cqw;padding:.9cqw .3cqw;white-space:nowrap;}
  table.bcfg th.sub{white-space:nowrap;}
  /* ---- slide 12: tariff graph + cards ---- */
  .l12{flex:1;display:grid;grid-template-columns:1.18fr 0.82fr;gap:2.2cqw;margin-top:1cqw;align-items:center;min-height:0;}
  .l12graph{background:#fff;border:1px solid var(--rowbd);border-radius:1.4cqw;padding:.8cqw;
    display:flex;align-items:center;justify-content:center;box-shadow:0 1px 3px rgba(0,0,0,.05);}
  .l12graph img{width:100%;height:100%;object-fit:contain;}
  .l12cards{display:flex;flex-direction:column;gap:1.4cqw;justify-content:center;}
  .tcard{background:#fff;border:1px solid var(--rowbd);border-left:.8cqw solid var(--accent,var(--pine));
    border-radius:1.4cqw;padding:1.4cqw 1.7cqw;box-shadow:0 1px 3px rgba(0,0,0,.05);}
  .tcard h5{font-size:2.15cqw;font-weight:800;color:var(--pine);margin:0;line-height:1.1;}
  .tcard p{font-size:1.62cqw;color:#33403a;margin:.6cqw 0 0;line-height:1.32;}
  .tcard.gold{--accent:#9c6a15;} .tcard.teal{--accent:#1f7a5a;} .tcard.red{--accent:#B23A3A;} .tcard.blue{--accent:#2a5a7a;}
  .tcard h5 b{color:var(--accent);}

  /* ---- slide 13: PV dominant — cards + city chart ---- */
  .l13{flex:1;display:grid;grid-template-columns:0.82fr 1.15fr;gap:2.2cqw;margin-top:1cqw;align-items:center;min-height:0;}
  .l13left{display:flex;flex-direction:column;gap:.9cqw;justify-content:center;}
  .l13graph{background:#fff;border:1px solid var(--rowbd);border-radius:1.4cqw;padding:.8cqw .8cqw .4cqw;
    display:flex;flex-direction:column;align-items:center;box-shadow:0 1px 3px rgba(0,0,0,.05);}
  .l13graph img{width:100%;height:auto;object-fit:contain;}
  .l13cap{font-size:1.45cqw;color:#9C6A15;font-style:italic;margin:.3cqw 0 .3cqw;text-align:center;}
  .rule13{background:var(--pine);color:#fff;border-radius:1.4cqw;padding:1cqw 1.7cqw;font-size:1.8cqw;font-weight:800;line-height:1.22;}
  .rule13 b{color:#f4cd78;}

  /* ---- slide 14: battery sizing table ---- */
  .l14{flex:1;display:flex;flex-direction:column;justify-content:center;margin-top:.5cqw;}
  table.mtable{width:100%;border-collapse:collapse;font-variant-numeric:tabular-nums;}
  table.mtable th{font-size:1.62cqw;color:var(--mut);text-transform:uppercase;letter-spacing:.04em;
    padding:.8cqw 1.2cqw;border-bottom:.4cqw solid var(--pine);text-align:center;font-weight:700;}
  table.mtable th:first-child{text-align:left;}
  table.mtable td{font-size:2.05cqw;font-weight:700;padding:.82cqw 1.2cqw;text-align:center;
    border-bottom:.16cqw solid #dde3dd;color:var(--ink);}
  table.mtable td:first-child{text-align:left;color:var(--pine);font-weight:800;}
  table.mtable tr.hot td{background:#fbeed2;}
  table.mtable tr.hot td:first-child{color:#9c6a15;}
  table.mtable td.g{color:#1f7a5a;} table.mtable td.o{color:#9c6a15;} table.mtable td.r{color:#B23A3A;}
  .bl14{margin-top:1.2cqw;background:var(--pine);color:#fff;border-radius:1.5cqw;padding:1.3cqw 2.4cqw;
    font-size:1.95cqw;font-weight:700;line-height:1.3;text-align:center;}
  .bl14 b{color:#f4cd78;}

  /* ---- slide 18: four answers (Q1-Q4), old colored-row style ---- */
  .l18{flex:1;display:flex;flex-direction:column;justify-content:center;gap:.9cqw;margin-top:.5cqw;}
  .a18row{display:grid;grid-template-columns:auto 1fr;align-items:center;gap:2.2cqw;background:#fff;
    border:1px solid var(--rowbd);border-left:.85cqw solid var(--accent,var(--pine));border-radius:1.4cqw;
    padding:.95cqw 2.2cqw;box-shadow:0 1px 3px rgba(0,0,0,.04);}
  .a18row .qc{background:var(--accent,var(--amber));color:#fff;font-weight:800;font-size:1.85cqw;
    border-radius:1cqw;padding:.5cqw 1.3cqw;flex:none;white-space:nowrap;}
  .a18row .q{font-size:1.5cqw;font-weight:800;color:var(--mut);text-transform:uppercase;letter-spacing:.04em;}
  .a18row .ans{font-size:2.05cqw;font-weight:700;color:var(--ink);line-height:1.18;margin-top:.2cqw;}
  .a18row .ans b{color:var(--accent);font-weight:800;}
  .a18row.gold{--accent:#9c6a15;} .a18row.teal{--accent:#1f7a5a;} .a18row.blue{--accent:#2a5a7a;} .a18row.pine{--accent:#12514A;}
  .bl18{margin-top:.9cqw;background:var(--pine);color:#fff;border-radius:1.5cqw;padding:1.1cqw 2.4cqw;
    font-size:1.85cqw;font-weight:700;line-height:1.28;text-align:center;}
  .bl18 b{color:#f4cd78;}

  /* ---- slide 19: insight -> design-rule cards + unifying strip ---- */
  .l19{flex:1;display:flex;flex-direction:column;margin-top:.8cqw;min-height:0;}
  .l19row{flex:1;display:grid;grid-template-columns:repeat(3,1fr);gap:1.7cqw;min-height:0;}
  .ins19{background:#fff;border:1px solid var(--rowbd);border-top:.8cqw solid var(--accent,var(--pine));
    border-radius:1.6cqw;padding:1.3cqw 1.45cqw 1.25cqw;display:flex;flex-direction:column;
    box-shadow:0 1px 3px rgba(0,0,0,.05);}
  .ins19 .ilab{font-size:1.5cqw;font-weight:800;color:var(--accent);text-transform:uppercase;letter-spacing:.06em;}
  .ins19 h5{margin:.4cqw 0 0;font-size:2.4cqw;font-weight:800;color:var(--pine);line-height:1.05;}
  .ins19 p{margin:.6cqw 0 1.0cqw;font-size:1.58cqw;color:#33403a;line-height:1.28;}
  .ins19 .rule{margin-top:auto;background:var(--accent-bg);border-radius:1.1cqw;
    padding:.85cqw 1.25cqw;font-size:1.7cqw;font-weight:800;line-height:1.2;color:var(--accent);}
  .ins19 .rule .rk{text-transform:uppercase;letter-spacing:.05em;font-size:1.25cqw;display:block;margin-bottom:.18cqw;opacity:.85;}
  .ins19.teal{--accent:#1f7a5a;--accent-bg:#e2f0ea;}
  .ins19.gold{--accent:#9c6a15;--accent-bg:#fbeed2;}
  .ins19.blue{--accent:#2a5a7a;--accent-bg:#eaf0f5;}
  .strip19{margin-top:1.1cqw;background:var(--pine);border-radius:1.4cqw;padding:1.25cqw 2.4cqw;text-align:center;}
  .strip19 .big{font-size:1.9cqw;font-weight:800;color:#f4cd78;line-height:1.24;}
  .strip19 .big b{color:#fff;}

  /* cover (slide 1, approved) */
  .cover{background:linear-gradient(135deg,#0d3f39,#12514A 55%,#17635a);color:#fff;}
  .cover .pad{justify-content:center;}
  .cover .deg{font-size:1.7cqw;letter-spacing:.12em;text-transform:uppercase;color:#bfe0d6;font-weight:700;}
  .cover h2{font-size:5.2cqw;line-height:1.08;font-weight:800;margin:1.4cqw 0 0;max-width:90%;text-wrap:balance;}
  .cover .tag{font-size:2.05cqw;color:#d7e8e2;margin:1.8cqw 0 0;max-width:80%;line-height:1.35;}
  .cover .cq{margin-top:2.6cqw;font-size:2.5cqw;line-height:1.28;color:#f4cd78;font-weight:800;
    border-left:.75cqw solid var(--amber);padding-left:2.2cqw;max-width:84%;}
  .cover .cq b{color:#ffe1a6;}
  .cover .who{margin-top:3cqw;font-size:1.75cqw;color:#eaf4f0;} .cover .who b{font-size:2.25cqw;display:block;font-weight:800;}
  .cover .ring{position:absolute;right:-8cqw;bottom:-12cqw;width:40cqw;height:40cqw;border-radius:50%;border:5cqw solid var(--amber);opacity:.26;}
  .cover .ring2{position:absolute;right:2cqw;bottom:-4cqw;width:14cqw;height:14cqw;border-radius:50%;background:var(--amber);opacity:.9;}

  /* ---- slide 20: limitations -> future rows ---- */
  .l20{flex:1;display:flex;flex-direction:column;justify-content:center;gap:1.05cqw;margin-top:.7cqw;}
  .limrow{display:grid;grid-template-columns:auto 1.0fr auto 1.15fr;align-items:center;gap:1.6cqw;
    background:#fff;border:1px solid var(--rowbd);border-left:.8cqw solid var(--accent,var(--pine));
    border-radius:1.3cqw;padding:.95cqw 2cqw;box-shadow:0 1px 3px rgba(0,0,0,.04);}
  .limrow .ln{width:3.9cqw;height:3.9cqw;border-radius:50%;background:var(--amber);color:#fff;flex:none;
    display:flex;align-items:center;justify-content:center;font-weight:800;font-size:1.95cqw;}
  .limrow .lm{font-size:1.78cqw;font-weight:800;color:var(--pine);line-height:1.14;}
  .limrow .lm small{display:block;font-size:1.36cqw;font-weight:600;color:var(--mut);margin-top:.3cqw;line-height:1.22;}
  .limrow .ar{color:var(--amber);font-size:2.3cqw;font-weight:800;justify-self:center;}
  .limrow .fu{font-size:1.66cqw;font-weight:800;color:#1f7a5a;line-height:1.2;}
  .limrow.teal{--accent:#1f7a5a;} .limrow.gold{--accent:#9c6a15;} .limrow.blue{--accent:#2a5a7a;} .limrow.red{--accent:#B23A3A;}

  .cap{margin-top:12px;font-size:.9rem;color:var(--cap-fg);line-height:1.55;background:var(--panel);
    border:1px solid var(--hair);border-radius:8px;padding:13px 16px;}
  .cap b{color:var(--page-fg);} .cap ul{margin:.5em 0 0;padding-inline-start:1.2em;} .cap li{margin:.25em 0;}
  footer{margin-top:44px;color:var(--cap-fg);font-size:.85rem;text-align:center;line-height:1.6;}

/* ---- slide 15: economics decomposition ---- */
.l15{flex:1;display:flex;flex-direction:column;justify-content:center;gap:1.5cqw;margin-top:.3cqw;}
.ctx15{background:#e2f0ea;border:1px solid #cfe3d8;border-left:.85cqw solid var(--teal);border-radius:1.4cqw;
  padding:1.15cqw 2.2cqw;font-size:1.9cqw;color:var(--ink);line-height:1.28;font-weight:600;}
.ctx15 b{color:var(--pine);}
.eqrow{display:flex;align-items:stretch;gap:1.0cqw;}
.op15{display:flex;align-items:center;justify-content:center;font-size:4.0cqw;font-weight:800;color:var(--mut);flex:0 0 auto;}
.ecard{flex:1;background:#fff;border:1px solid var(--rowbd);border-top:.9cqw solid var(--accent,var(--pine));
  border-radius:1.5cqw;padding:1.6cqw 1.3cqw 1.5cqw;display:flex;flex-direction:column;align-items:center;text-align:center;
  box-shadow:0 1px 3px rgba(0,0,0,.05);}
.ecard .elab{font-size:1.5cqw;text-transform:uppercase;letter-spacing:.045em;color:var(--mut);font-weight:800;line-height:1.15;}
.ecard .enum{font-size:4.3cqw;font-weight:800;line-height:1;margin:.5cqw 0 .25cqw;color:var(--accent,var(--pine));font-variant-numeric:tabular-nums;}
.ecard .eunit{font-size:1.48cqw;color:var(--mut);font-weight:700;margin-bottom:.5cqw;}
.ecard .esub{font-size:1.58cqw;color:var(--ink);line-height:1.22;}
.ecard.teal{--accent:#1f7a5a;} .ecard.red{--accent:#B23A3A;} .ecard.net{--accent:#9C6A15;}
.ecard.net{background:#fbeed2;border:1px solid #ecd9a8;border-top:.9cqw solid #9C6A15;}
.ecard.net .enum{font-size:4.9cqw;}

/* slide 15 fit tightening */
.l15{gap:1.0cqw;margin-top:.15cqw;}
.l15 .bl14{margin-top:0;padding:1.0cqw 2.2cqw;font-size:1.78cqw;}
.ctx15{padding:.85cqw 2.0cqw;font-size:1.78cqw;line-height:1.25;}
.ecard{padding:1.15cqw 1.2cqw 1.05cqw;}
.ecard .enum{font-size:3.9cqw;margin:.3cqw 0 .18cqw;}
.ecard.net .enum{font-size:4.4cqw;}
.ecard .esub{font-size:1.5cqw;line-height:1.2;}
.op15{font-size:3.6cqw;}


  /* ---- slide 15: economics — full-system hero + battery-contribution equation ---- */
  .l15{flex:1;display:flex;flex-direction:column;justify-content:center;gap:1.3cqw;margin-top:.5cqw;}
  .hero15{background:var(--pine);border-radius:1.8cqw;padding:1.6cqw 2.4cqw;display:flex;align-items:center;gap:2.4cqw;}
  .hero15 .num{font-size:5.6cqw;font-weight:800;color:var(--amber);line-height:.9;letter-spacing:-.02em;
    font-variant-numeric:tabular-nums;white-space:nowrap;flex:none;}
  .hero15 .txt{color:#eaf4ef;font-size:2cqw;line-height:1.32;font-weight:600;}
  .hero15 .txt b{color:#fff;font-weight:800;}
  .clabel15{font-size:1.62cqw;font-weight:800;color:var(--mut);text-transform:uppercase;letter-spacing:.05em;
    text-align:center;margin-top:.2cqw;}
  .eq15{display:grid;grid-template-columns:1fr auto 1fr auto 1fr;align-items:stretch;gap:1cqw;}
  .eq15 .op{align-self:center;font-size:3.6cqw;font-weight:800;color:var(--mut);}
  .tcard15{background:#fff;border:1px solid var(--rowbd);border-top:.85cqw solid var(--accent,var(--pine));
    border-radius:1.5cqw;padding:1.3cqw 1.2cqw;text-align:center;box-shadow:0 1px 3px rgba(0,0,0,.05);
    display:flex;flex-direction:column;justify-content:center;}
  .tcard15 .v{font-size:4cqw;font-weight:800;color:var(--accent);line-height:1;font-variant-numeric:tabular-nums;}
  .tcard15 .k{font-size:1.55cqw;color:var(--mut);margin-top:.6cqw;line-height:1.22;font-weight:600;}
  .tcard15.teal{--accent:#1f7a5a;} .tcard15.red{--accent:#B23A3A;} .tcard15.gold{--accent:#9c6a15;}
.sub13{font-size:1.5cqw;}

/* ===== slide 15 v2 — waterfall ===== */
.l15w{flex:1;display:flex;gap:2.2cqw;margin-top:.4cqw;align-items:stretch;}
.l15w .wchart{flex:0 0 60%;display:flex;align-items:center;justify-content:center;
  background:#fff;border:1px solid var(--rowbd);border-radius:1.6cqw;padding:1.4cqw 1.2cqw;box-shadow:0 1px 3px rgba(0,0,0,.05);}
.l15w{min-height:0;}
.l15w .wchart{min-width:0;min-height:0;overflow:hidden;}
.l15w .wchart svg{width:100%;height:100%;display:block;}
.l15side{flex:1;display:flex;flex-direction:column;justify-content:center;gap:1.5cqw;}
.netcard{background:#fbeed2;border:1px solid #ecd9a8;border-top:.9cqw solid #9C6A15;border-radius:1.5cqw;
  padding:1.5cqw 1.8cqw;text-align:center;}
.netcard .nn{font-size:5.2cqw;font-weight:800;color:#9C6A15;line-height:1;font-variant-numeric:tabular-nums;}
.netcard .nu{font-size:1.55cqw;color:var(--mut);font-weight:700;margin-top:.3cqw;}
.netcard .nd{font-size:1.6cqw;color:var(--ink);margin-top:.7cqw;line-height:1.25;}
.scard{background:#fff;border:1px solid var(--rowbd);border-left:.7cqw solid var(--accent,var(--pine));
  border-radius:1.3cqw;padding:1.15cqw 1.6cqw;font-size:1.68cqw;line-height:1.28;color:var(--ink);}
.scard.teal{--accent:#1f7a5a;} .scard.red{--accent:#B23A3A;}
.scard b{color:var(--pine);}

.wrap{padding:24px;background:#e9ebe6;}

/* tighten v2 */
.l15w{gap:1.8cqw;margin-top:.2cqw;}
.l15side{gap:.8cqw;}
.netcard{padding:1.1cqw 1.6cqw;}
.netcard .nn{font-size:4.6cqw;}
.netcard .nd{margin-top:.5cqw;font-size:1.55cqw;}
.scard{padding:.95cqw 1.5cqw;font-size:1.6cqw;}

/* enlarge chart */
.l15w{gap:1.5cqw;}
.l15w .wchart{flex:0 0 55%;padding:1.0cqw;}

/* slide15 v3 — buy/sell breakdown table */
.l15hd{font-size:2.15cqw;font-weight:800;color:var(--pine);margin-bottom:.2cqw;}
.l15hd b{color:#9C6A15;}
.bstable{width:100%;border-collapse:collapse;font-variant-numeric:tabular-nums;white-space:nowrap;}
.bstable th{font-size:1.6cqw;text-transform:uppercase;letter-spacing:.02em;color:var(--mut);font-weight:800;padding:.5cqw .32cqw;border-bottom:.2cqw solid var(--pine);text-align:right;}
.bstable td{font-size:1.9cqw;padding:.55cqw .32cqw;border-bottom:1px solid var(--rowbd);text-align:right;font-weight:700;color:var(--ink);}
.bstable td.rl{text-align:left;font-weight:600;}
.bstable td.g{color:#1f7a5a;} .bstable td.r{color:#B23A3A;}
.netbar{margin-top:.6cqw;background:var(--pine);color:#fff;border-radius:1.1cqw;padding:1.0cqw 1.2cqw;font-size:2.0cqw;text-align:center;line-height:1.2;}
.netbar .o{color:#f4cd78;}
.abuy{color:#2a5a7a;font-weight:800;}
.asell{color:#9C6A15;font-weight:800;}
.sub15{font-size:1.5cqw;}


/* slide 21 bookend */
.endslide .endrows{display:flex;flex-direction:column;gap:1.15cqw;margin-top:1.6cqw;}
.endslide .erow{display:flex;align-items:center;gap:1.4cqw;font-size:2.4cqw;font-weight:600;color:#eaf3ee;}
.endslide .erow .ei{flex:0 0 auto;width:3.4cqw;height:3.4cqw;border-radius:50%;background:var(--amber);color:#12332e;
  display:flex;align-items:center;justify-content:center;font-weight:800;font-size:1.9cqw;}
.endslide .erow b{color:#f4cd78;}



/* ============ presentation mode ============ */
*{box-sizing:border-box;}
html,body{margin:0;height:100%;background:#0b0d0c;overflow:hidden;}
#deck{position:fixed;inset:0;}
.pslide{position:absolute;inset:0;display:none;}
.pslide.active{display:grid;place-items:center;}
.stage{width:min(100vw,177.78vh);aspect-ratio:16/9;}
.pslide .slide{width:100%;height:100%;border-radius:0;box-shadow:none;border:0;}
#hud{position:fixed;bottom:10px;left:0;right:0;display:flex;justify-content:center;gap:12px;
  align-items:center;color:#c6d0ca;font:600 13px system-ui,-apple-system,sans-serif;opacity:.5;z-index:20;
  pointer-events:none;transition:opacity .45s ease;}
#hud.hide{opacity:0;}
#hud .k{opacity:.7;font-weight:500;font-size:11px;}


/* render override: exact 1920x1080 frame, one slide */
html,body{margin:0;padding:0;width:1920px;height:1080px;overflow:hidden;background:#ffffff;}
#rstage{width:1920px;height:1080px;position:relative;}
#rstage .slide{width:1920px;height:1080px;border-radius:0;box-shadow:none;border:0;}
#hud{display:none !important;}
</style></head><body><div id="rstage"><div class="slide">
      <div class="pad">
        <div class="kick">Tariff Structure</div>
        <div class="snum">12</div>
        <h1 class="ttl">Dynamic Time-of-Use (ToU) tariff</h1>
        <div class="l12">
          <div class="l12graph"><img alt="Weekday ToU purchase tariff" src="data:image/png;base64,"></div>
          <div class="l12cards">
            <div class="tcard gold"><h5>Evening peak · 17–22 h</h5><p>Summer <b>×3.2</b> · Winter ×2.6 · Transition ×1.1 above off-peak.</p></div>
            <div class="tcard teal"><h5>Storage captures the spread</h5><p>Charge cheap by day → discharge at the peak. You <b>SELL</b> surplus at a flat <b>35.40 ag/kWh</b> — below every buy rate.</p></div>
            <div class="tcard red"><h5>The tariff decides viability</h5><p>A tariff change can flip a system <b>viable ↔ unviable</b>.</p></div>
          </div>
        </div>
      </div>
    </div></div></body></html>